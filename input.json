{
    "authorUrl": "https://medium.com/@medium",
    "maxPosts": 100,
    "includeArticleContent": true,
    "outputFormat": "json",
    "cacheEnabled": true,
    "rateLimit": {
        "requestsPerMinute": 30,
        "randomDelay": [2, 5]
    },
    "proxy": {
        "useProxy": false,
        "proxyUrls": []
    },
    "recaptchaBypass": false,
    "premiumHandling": "include-summary"
} 